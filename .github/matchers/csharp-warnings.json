{
  "problemMatcher": [
    {
      "owner": "csharp-warnings",
      "pattern": [
        {
          "regexp": "^(.*)\\((\\d+),(\\d+)\\): warning (CS\\d+): (.*)$",
          "file": 1,
          "line": 2,
          "column": 3,
          "code": 4,
          "message": 5,
          "severity": "warning"
        }
      ]
    }
  ]
}